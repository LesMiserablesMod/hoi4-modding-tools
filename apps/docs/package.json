{
  "name": "@hoi4-modding-tools/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "node scripts/dev.mjs --webpack --disable-source-maps",
    "dev:turbo": "node scripts/dev.mjs --turbo",
    "start": "next start",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/tokenizers": "^3.1.18",
    "fumadocs-core": "16.8.0",
    "fumadocs-mdx": "14.3.1",
    "fumadocs-ui": "16.8.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  }
}
